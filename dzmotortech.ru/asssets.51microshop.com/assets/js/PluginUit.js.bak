$(document).ready(function () {
   if(getUrlpara("usertemplateid")==""&&getUrlpara("review")==""){
    setTimeout(function () {
        $.ajax({
            type: "Get",
            url: "/snippets/js.aspx",
            beforeSend: function (XMLHttpRequest) {
            },
            success: function (data) {
                $('body').append(data);
            },
            complete: function (XMLHttpRequest, textStatus) {
            },
            error: function () {
            }
        });
    }, 100);}
});

